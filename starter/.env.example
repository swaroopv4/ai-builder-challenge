# Upstream API base URL (must include the /v1 prefix).
# For local dev, point at the API in this monorepo: http://localhost:8080/v1
API_BASE_URL=http://localhost:8080/v1

# Your bearer token. Treat as secret. Stays server-side; never exposed to the
# browser. Browser requests are proxied through /api/upstream which attaches it.
API_TOKEN=local-dev-token-1234567890
